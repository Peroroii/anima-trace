{
  "name": "anima-trace",
  "version": "1.0.0",
  "description": "Self-verifying trace format for deterministic ANIMA runs. Record a run, and anyone can reproduce it byte-for-byte and prove it wasn't tampered with. Executable reproducibility for AI-safety auditing.",
  "main": "trace.js",
  "bin": {
    "anima-verify": "./cli.js"
  },
  "files": [
    "trace.js",
    "cli.js",
    "src/",
    "SCHEMA.md",
    "example_trace.json"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "verify": "node cli.js example_trace.json"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 85,
        "functions": 80
      }
    }
  },
  "keywords": [
    "ai-safety",
    "reproducibility",
    "provenance",
    "verification",
    "audit",
    "deterministic",
    "integrity",
    "tamper-evident"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "jest": "^30.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Peroroii/anima-trace.git"
  },
  "author": "Ariel Fernández",
  "bugs": {
    "url": "https://github.com/Peroroii/anima-trace/issues"
  },
  "homepage": "https://github.com/Peroroii/anima-trace#readme"
}
